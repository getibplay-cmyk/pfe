APP_NAME=RentFleet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.invalid
APP_TIMEZONE=Africa/Casablanca
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# Les seeders de démonstration sont interdits en production ; cette valeur doit rester vide.
DEMO_PASSWORD=

LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rentfleet
DB_USERNAME=rentfleet_app
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
PRIVATE_DOCUMENT_MAX_KB=10240
# Pour un volume persistant externe, définir PRIVATE_DOCUMENT_ROOT hors du dépôt.

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database
SCHEDULER_HEARTBEAT_MAX_AGE_MINUTES=5

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true

VITE_APP_NAME="${APP_NAME}"
